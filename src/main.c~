void ablum_interface()
{
    // b. 相册界面
    lcd_draw_bmp("album.bmp", 0, 0, 800, 480);
    // 相册界面：上一张
    lcd_draw_bmp("prev.bmp", 100, 100, 200, 200);
    // 相册界面：下一张
    lcd_draw_bmp("next.bmp", 600, 100, 200, 200);
    // 关闭
